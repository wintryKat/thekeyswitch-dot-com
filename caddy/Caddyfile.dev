{
    # No CrowdSec in development
    auto_https off
}

:80 {
    log {
        output stdout
        format console
    }

    route {
        # API proxy
        handle /graphql* {
            reverse_proxy api:8080
        }

        # Actuator health
        handle /actuator/* {
            reverse_proxy api:8080
        }

        # Next.js application
        handle {
            reverse_proxy frontend:3000
        }
    }
}
